# ============================================================
# .gitignore — Biorreactor Qt6/C++ + Python
# ============================================================

# ------------------------------------
# Artefactos de compilacion (Qt/CMake)
# ------------------------------------
build/
*.o
*.obj
*.a
*.lib
*.dll
*.exe
*.out
*.app
*.pdb
*.ilk

# Archivos generados por moc/uic/rcc de Qt
*_autogen/
moc_*.cpp
moc_predefs.h
qrc_*.cpp
ui_*.h

# Cache de QML compilado
.rcc/
*.qmlc
*.jsc

# ------------------------------------
# Archivos de Qt Creator / CMake
# ------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
*.user
*.user.*
*.pro.user
.qmake.stash
.qmake.cache

# ------------------------------------
# Python
# ------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.env
venv/
.venv/
*.egg-info/

# ------------------------------------
# Audio generado (se regenera con generar_sonidos.py)
# ------------------------------------
audio/*.wav
audio/*.mp3
audio/*.ogg

# ------------------------------------
# Archivos de sistema operativo
# ------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------
# IDEs y editores
# ------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------
# Archivos internos de Claude Code
# ------------------------------------
.claude/

# ------------------------------------
# Bases de datos y datos de usuario en runtime
# ------------------------------------
*.db
*.sqlite
*.sqlite3
proyectos/
registros/
logs/
